# ===========================================
# AI Studio Worker — Environment Configuration
# ===========================================

# Worker Identity
WORKER_NAME=ai-studio-worker-01
WORKER_VERSION=0.1.0

# Backend Connection
BACKEND_URL=http://localhost:8000

# Polling
POLL_INTERVAL=5

# -------------------------------------------
# Image Provider
# -------------------------------------------
# Options: mock, flux
IMAGE_PROVIDER=mock

# -------------------------------------------
# Storage Provider
# -------------------------------------------
# Options: local
STORAGE_PROVIDER=local

# -------------------------------------------
# Hugging Face / FLUX Configuration
# Required only when IMAGE_PROVIDER=flux
# -------------------------------------------
HF_TOKEN=
HF_PROVIDER=fal-ai
HF_MODEL=black-forest-labs/FLUX.1-dev
HF_TIMEOUT=120
